# ============================================================
# Template — copy to .env.local for local dev OR set in Vercel
# Project Settings → Environment Variables for prod web build.
# ============================================================

# ─── Supabase (client / EXPO_PUBLIC_*) ───────────────────────
# These ship in the client bundle. The anon key is intentionally public —
# Supabase row-level security enforces actual access control.
#
# For LOCAL dev (after `supabase start`), use:
#   EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=<value printed by `supabase status`>
#
# For PROD: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ─── Web Push (client) ───────────────────────────────────────
# Public half of a VAPID key pair. Generate with:
#   npx web-push generate-vapid-keys
# The private half goes in supabase/functions/.env.local (local) or
# `supabase secrets set VAPID_PRIVATE=...` (prod).
EXPO_PUBLIC_VAPID_PUBLIC_KEY=

# ─── EAS / Expo build (optional) ─────────────────────────────
# Only needed for native builds via `eas build`.
EXPO_PROJECT_ID=

# ─── Feature flags (client) ──────────────────────────────────
# EXPO_PUBLIC_NEW_UI: opts the client into the new UI path. Currently
# pre-staged on Vercel (Preview + Production) ahead of the rollout —
# set to `true` locally to keep dev builds consistent with deployed
# behavior.
EXPO_PUBLIC_NEW_UI=

# ============================================================
# Edge Function secrets — NOT loaded from this file in prod.
# Set them with: `supabase secrets set KEY=VALUE` (per project).
# For LOCAL dev, set them in supabase/functions/.env.local instead.
# Listed here so the full set is documented in one place.
# ============================================================
#
# RESEND_API_KEY            Transactional email via resend.com
# RESEND_FROM_ADDRESS       Sender (default: onboarding@resend.dev)
# VAPID_PUBLIC              Web push — public half (must match EXPO_PUBLIC_VAPID_PUBLIC_KEY)
# VAPID_PRIVATE             Web push — private half
# VAPID_SUBJECT             mailto: address for VAPID JWT
# BREADBOT_API_KEY          POS integration auth
# BREADBOT_BASE_URL         POS endpoint (optional, has prod fallback)
# BREADBOT_CRON_SECRET      Shared bearer for breadbot cron auth
# DEFAULT_TIMEZONE          IANA TZ string (default: America/New_York)
# PWA_SERVICE_TOKEN         Bearer token for the pwa-catalog Edge Function.
#                           The first-party PWA's backend signs each catalog
#                           fetch with this; rotate independently of any
#                           staff-app token.
#
# Auto-injected by `supabase functions serve` — don't set manually:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_URL
