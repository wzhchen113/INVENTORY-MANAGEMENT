# Local dev — Edge Function secrets when running `supabase functions serve`.
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored
# (supabase/.gitignore).
#
# Auto-injected by Supabase CLI (do NOT set here):
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_URL

# ─── Staff app integration (Phase 13) ────────────────────────
# Bearer token the staff app's backend signs every Edge Function call with.
# Long-lived; rotate by:
#   1. set new value here + in prod (Supabase Studio → Settings → Functions)
#   2. communicate to staff app team out-of-band
#   3. they update their secret + redeploy
#   4. (optional) keep both old + new valid via STAFF_SERVICE_TOKEN_PREV
#      env var during the rollover window — see staff-catalog/index.ts
# Local dev token below is pinned for predictability — change for prod.
STAFF_SERVICE_TOKEN=dev_staff_token_change_me_for_prod

# ─── Breadbot integration (POS) ──────────────────────────────
BREADBOT_API_KEY=dev_dummy_breadbot_key
BREADBOT_BASE_URL=http://127.0.0.1:9999/breadbot-not-real
BREADBOT_CRON_SECRET=dev_cron_secret_change_me

# ─── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev

# ─── VAPID web push ──────────────────────────────────────────
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:dev@local.test

# ─── Misc ────────────────────────────────────────────────────
DEFAULT_TIMEZONE=America/New_York
