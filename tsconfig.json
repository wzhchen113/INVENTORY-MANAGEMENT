{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "tests/**/*",
    "supabase/functions/**",
    "scripts/**",
    "e2e/**",
    "playwright.config.ts"
  ]
}
