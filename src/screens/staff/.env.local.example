# imr-staff env vars — copy to .env.local for local dev.
#
# Local: defaults below point at the shared imr-inventory supabase
# stack (boot it with `cd ../INVENTORY-MANAGEMENT && npm run dev:db`).
#
# Production: set EXPO_PUBLIC_SUPABASE_URL to the prod project URL
# and EXPO_PUBLIC_SUPABASE_ANON_KEY to the prod publishable anon key
# (NOT a service-role key — the staff app authenticates with each
# user's own credentials via supabase-js).

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
